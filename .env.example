GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Auth: verify Better Auth JWTs against its JWKS (set in Phase 3) ──
# Public keys endpoint, e.g. https://<frontend-domain>/api/auth/jwks
BETTER_AUTH_JWKS_URL=
# Expected `iss` claim, e.g. https://<frontend-domain>
BETTER_AUTH_ISSUER=